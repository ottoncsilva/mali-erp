rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Fotos de produtos e logos: leitura pública (exibidas em orçamentos),
    // escrita apenas para usuários autenticados.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
