rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Função auxiliar: usuário autenticado
    function isAuth() {
      return request.auth != null;
    }

    // Perfil do usuário que está fazendo a requisição (lê o próprio doc).
    function perfilAtual() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.perfil;
    }

    // Gestores: admin e gerência.
    function isGestor() {
      return isAuth() && perfilAtual() in ['admin', 'gerencia'];
    }

    // Quem pode mexer no financeiro.
    function podeFinanceiro() {
      return isAuth() && perfilAtual() in ['admin', 'gerencia', 'financeiro'];
    }

    // ATENDIMENTOS (Orçamentos e Vendas)
    // - Leitura pública APENAS de orçamentos (para o link público do cliente).
    // - Vendas e escrita exigem autenticação.
    match /atendimentos/{id} {
      allow read: if isAuth() || resource.data.tipo == 'orcamento';
      allow write: if isAuth();
    }

    // CATÁLOGO PÚBLICO
    // Produtos e acabamentos não são sensíveis e são necessários para
    // renderizar nomes/fotos na página pública de orçamento.
    match /produtos/{id} {
      allow read: if true;
      allow write: if isAuth();
    }

    match /variaveis_acabamento/{id} {
      allow read: if true;
      allow write: if isAuth();
    }

    // DADOS PRIVADOS (somente autenticado)
    // Clientes contêm dados pessoais (LGPD) — nunca expostos publicamente.
    // A página pública usa os dados denormalizados dentro do atendimento.
    match /clientes/{id} {
      allow read, write: if isAuth();
    }

    // Demais coleções privadas
    match /categorias/{id} {
      allow read, write: if isAuth();
    }

    match /fornecedores/{id} {
      allow read, write: if isAuth();
    }

    // USUÁRIOS — dados de acesso e perfil (sensível).
    // - Leitura por qualquer autenticado (a UI precisa listar/identificar).
    // - Criação: o próprio usuário (bootstrap no 1º login) ou um gestor (convite).
    // - Edição/exclusão: apenas gestores (admin/gerência) definem perfil/ativo.
    match /usuarios/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && (request.auth.uid == id || isGestor());
      allow update, delete: if isGestor();
    }

    // CONFIGURAÇÕES DA EMPRESA (precificação, dados) — só gestores escrevem.
    match /empresa/{id} {
      allow read: if isAuth();
      allow write: if isGestor();
    }

    // CARGOS (perfis de acesso e comissão) — leitura autenticada (a UI/login
    // precisa resolver permissões); escrita só por quem gere usuários (gestor).
    match /cargos/{id} {
      allow read: if isAuth();
      allow write: if isGestor();
    }

    // FINANCEIRO — leitura autenticada, escrita restrita.
    // - Contas a receber: criadas pelo PDV (vendedor fecha venda)
    //   ou pelo sistema (transferência de parcelas).
    //   Update/delete (ajuste de parcelas): apenas podeFinanceiro().
    // - Contas a pagar: criadas no PDV (comissão) ou no NF (fornecedor).
    //   Update/delete: apenas podeFinanceiro().
    match /contas_receber/{id} {
      allow read: if isAuth();
      allow create: if isAuth(); // PDV fecha venda / sistema cria parcelamento
      allow update, delete: if podeFinanceiro();
    }

    match /contas_pagar/{id} {
      allow read: if isAuth();
      allow create: if isAuth(); // PDV comissão / NF fornecedor
      allow update, delete: if podeFinanceiro();
    }

    // CATEGORIAS FINANCEIRAS — plano de contas para classificação.
    // Leitura por autenticado; escrita só gestor.
    match /categorias_financeiras/{id} {
      allow read: if isAuth();
      allow write: if isGestor();
    }

    // CONTAS BANCÁRIAS — caixa, banco, carteira digital.
    // Leitura por autenticado; escrita só gestor (alterar saldo é crítico).
    match /contas_bancarias/{id} {
      allow read: if isAuth();
      allow write: if isGestor();
    }

    // MOVIMENTOS DE CAIXA — trilha imutável de entradas/saídas reais.
    // Leitura por autenticado; criação apenas por perfis financeiros (baixa de
    // parcelas roda em transação client-side). Edição/exclusão bloqueadas para
    // preservar a auditoria — estornos são feitos com NOVO movimento de reversão.
    match /movimentos_caixa/{id} {
      allow read: if isAuth();
      allow create: if podeFinanceiro();
      allow update, delete: if false;
    }

    // ENTREGAS & MONTAGEM e ASSISTÊNCIA TÉCNICA (operações).
    match /entregas/{id} {
      allow read, write: if isAuth();
    }

    match /assistencia_tecnica/{id} {
      allow read, write: if isAuth();
    }

    // ESTOQUE & COMPRAS
    // Saldos de estoque por localização (showroom, depósito, comprado, entrega).
    match /estoque/{id} {
      allow read, write: if isAuth();
    }

    // Trilha de auditoria de movimentações. Criação permitida (client-side via
    // transação); edição/exclusão bloqueadas para preservar o histórico.
    match /movimentacoes_estoque/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // Pedidos de compra e notas fiscais de entrada.
    match /pedidos_compra/{id} {
      allow read, write: if isAuth();
    }

    match /notas_fiscais/{id} {
      allow read, write: if isAuth();
    }

    // Contadores sequenciais (numeração de PC/NF).
    match /contadores/{id} {
      allow read, write: if isAuth();
    }

    // Depósitos (localizações físicas de estoque cadastráveis).
    match /depositos/{id} {
      allow read, write: if isAuth();
    }

    // Bloqueio padrão para qualquer outra coleção não listada
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
